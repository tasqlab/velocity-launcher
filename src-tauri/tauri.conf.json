{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Velocity Launcher",
  "version": "0.1.0",
  "identifier": "com.velocity.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Velocity Launcher",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": true,
        "center": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null,
      "dangerousUseIframePolicy": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "copyright": "Velocity Launcher",
    "category": "Game",
    "shortDescription": "High-performance Minecraft launcher",
    "longDescription": "Velocity Launcher - A high-performance, modular Minecraft launcher focused on speed and user customization"
  }
}

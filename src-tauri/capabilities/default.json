{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-close",
    "core:window:allow-set-size",
    "core:window:allow-set-fullscreen",
    "fs:default",
    "fs:allow-app-write",
    "fs:allow-app-read",
    "fs:allow-app-meta",
    "fs:allow-app-write-recursive",
    "fs:allow-app-read-recursive",
    "fs:allow-home-read",
    "fs:allow-home-write",
    "fs:allow-download-read",
    "fs:allow-download-write",
    "fs:allow-documents-read",
    "fs:allow-documents-write",
    "http:default",
    "http:allow-fetch",
    "shell:default",
    "shell:allow-open",
    "store:default",
    "store:allow-get",
    "store:allow-set",
    "store:allow-delete",
    "store:allow-clear",
    "store:allow-keys",
    "store:allow-values",
    "store:allow-length",
    "store:allow-load",
    "store:allow-save",
    "process:default",
    "process:allow-restart",
    "os:default",
    "os:allow-platform",
    "os:allow-version",
    "os:allow-os-type",
    "os:allow-arch",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install"
  ]
}
